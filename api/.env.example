DATABASE_URL=postgresql://mbuzzi:mbuzzi@localhost:5432/mbuzzi
PORT=3001

# On Render: set RENDER_DATABASE_REGION=frankfurt (or oregon, etc.) to match your DB region.
# Optional override (full host with *.render.com):
# DATABASE_EXTERNAL_URL=postgresql://...

# Cloudinary: DB stores short public_ids (mbuzzi-choma/one-1). API builds delivery URLs.
CLOUDINARY_CLOUD_NAME=your_cloud_name
# Optional default transforms (auto format/quality):
# CLOUDINARY_IMAGE_TRANSFORM=f_auto,q_auto,w_1200

# Only needed locally for npm run upload:cloudinary (never commit secrets):
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional admin guard (required for /api/admin/* when set)
ADMIN_API_KEY=change_me

# Checkout: standard delivery fee (UGX). Pickup and "far / pending" use 0.
DELIVERY_FEE_UGX=5000

# Required for Pesapal: public origin of this API (no trailing slash), e.g. https://mbuzzi-api.onrender.com
# API_PUBLIC_URL=

# Customer storefront origin for payment return redirect (no trailing slash), e.g. https://your-site.pages.dev
# CUSTOMER_APP_URL=

# Pesapal API 3 — https://developer.pesapal.com (sandbox credentials for testing)
# Register IPN URL in Pesapal dashboard: https://YOUR_API_ORIGIN/api/payments/pesapal/ipn → copy notification_id
# PESAPAL_ENVIRONMENT=sandbox
# PESAPAL_CONSUMER_KEY=
# PESAPAL_CONSUMER_SECRET=
# PESAPAL_IPN_NOTIFICATION_ID=
