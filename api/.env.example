DATABASE_URL=postgresql://mbuzzi:mbuzzi@localhost:5432/mbuzzi
PORT=3001

# On Render: set RENDER_DATABASE_REGION=frankfurt (or oregon, etc.) to match your DB region.
# Optional override (full host with *.render.com):
# DATABASE_EXTERNAL_URL=postgresql://...

# Cloudinary: DB stores short public_ids (mbuzzi-choma/one-1). API builds delivery URLs.
CLOUDINARY_CLOUD_NAME=your_cloud_name
# Optional default transforms (auto format/quality):
# CLOUDINARY_IMAGE_TRANSFORM=f_auto,q_auto,w_1200

# Only needed locally for npm run upload:cloudinary (never commit secrets):
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
