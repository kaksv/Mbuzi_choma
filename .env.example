# Leave empty for local dev: Vite proxies /api → http://127.0.0.1:3001 (run the API separately).
# Production build: set to your API origin, no trailing slash, e.g. https://mbuzzi-api.onrender.com
VITE_API_BASE_URL=

# Optional: same as API CLOUDINARY_CLOUD_NAME — resolves public_id / /choma/... in the browser
# if the API ever returns non-absolute photoUrl. If the API always sends https://res.cloudinary.com/...,
# you can omit these.
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_CLOUDINARY_IMAGE_TRANSFORM=f_auto,q_auto
